ENV=development
APP_NAME={{.ProjectName}}
APP_VERSION=1.0.0
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization
CORS_EXPOSE_HEADERS=Content-Length
CORS_ALLOW_CREDENTIALS=true
{{- if .Postgres}}

DB_POSTGRES_URL=postgres://postgres:postgres@localhost:5432/{{.ProjectName}}?sslmode=disable

# Docker Compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB={{.ProjectName}}
{{- end}}
{{- if .Redis}}

DB_REDIS_URL=redis://:redis_password@localhost:6379/0

# Docker Compose
REDIS_PASSWORD=redis_password
{{- end}}
{{- if .Centrifuge}}

CENTRIFUGE_PING_INTERVAL=25s
CENTRIFUGE_PONG_TIMEOUT=10s
{{- end}}
