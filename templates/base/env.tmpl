ENV=development
APP_NAME={{.ProjectName}}
APP_VERSION=1.0.0
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
{{- if .Postgres}}

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB={{.ProjectName}}
POSTGRES_SSL_MODE=disable
{{- end}}
{{- if .Redis}}

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_DB=0
{{- end}}
