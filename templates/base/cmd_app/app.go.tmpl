package main

import (
	"context"
	"os"
	"os/signal"
	"syscall"
	"time"

	"{{.ModuleName}}/pkg/httpserver"
{{- if .Postgres}}
	"{{.ModuleName}}/pkg/postgres"
{{- end}}
{{- if .Redis}}
	"{{.ModuleName}}/pkg/redis"
{{- end}}
	"go.uber.org/zap"
)

type App struct {
	logger     *zap.SugaredLogger
	httpServer *httpserver.Server
{{- if .Postgres}}
	pgPool     *postgres.Pool
{{- end}}
{{- if .Redis}}
	redisClient *redis.Client
{{- end}}
	shutdownTimeout time.Duration
}

func NewApp(
	logger *zap.SugaredLogger,
	httpServer *httpserver.Server,
{{- if .Postgres}}
	pgPool *postgres.Pool,
{{- end}}
{{- if .Redis}}
	redisClient *redis.Client,
{{- end}}
) *App {
	if logger == nil {
		panic("logger is required")
	}
	if httpServer == nil {
		panic("httpServer is required")
	}
{{- if .Postgres}}
	if pgPool != nil {
		logger.Info("PostgreSQL соединение установлено")
	}
{{- end}}
{{- if .Redis}}
	if redisClient != nil {
		logger.Info("Redis соединение установлено")
	}
{{- end}}

	return &App{
		logger:          logger,
		httpServer:      httpServer,
{{- if .Postgres}}
		pgPool:          pgPool,
{{- end}}
{{- if .Redis}}
		redisClient:     redisClient,
{{- end}}
		shutdownTimeout: 15 * time.Second,
	}
}

func (a *App) Run() error {
	a.logger.Info("Запуск приложения...")

	quit := make(chan os.Signal, 1)
	signal.Notify(quit, syscall.SIGINT, syscall.SIGTERM)

	go func() {
		a.logger.Info("HTTP сервер запущен")
		if err := a.httpServer.Start(); err != nil {
			a.logger.Fatalw("Ошибка HTTP сервера", "error", err)
		}
	}()

	<-quit
	a.logger.Info("Остановка приложения...")
	return a.shutdown()
}

func (a *App) shutdown() error {
	ctx, cancel := context.WithTimeout(context.Background(), a.shutdownTimeout)
	defer cancel()

	done := make(chan struct{})
	var shutdownErr error

	go func() {
		if err := a.httpServer.Close(ctx); err != nil {
			a.logger.Errorw("Ошибка остановки HTTP сервера", "error", err)
			shutdownErr = err
		} else {
			a.logger.Info("HTTP сервер остановлен")
		}
{{- if .Postgres}}

		if a.pgPool != nil {
			a.pgPool.Close()
			a.logger.Info("PostgreSQL соединение закрыто")
		}
{{- end}}
{{- if .Redis}}

		if a.redisClient != nil {
			if err := a.redisClient.Close(); err != nil {
				a.logger.Errorw("Ошибка закрытия Redis соединения", "error", err)
			} else {
				a.logger.Info("Redis соединение закрыто")
			}
		}
{{- end}}

		close(done)
	}()

	select {
	case <-done:
		a.logger.Info("Приложение остановлено корректно")
		return shutdownErr
	case <-ctx.Done():
		a.logger.Warn("Таймаут остановки, принудительное завершение")
		return ctx.Err()
	}
}
