package http_v1

import (
	"{{.ModuleName}}/internal/health"
	"github.com/gin-contrib/cors"
	"github.com/gin-gonic/gin"
	swaggerFiles "github.com/swaggo/files"
	ginSwagger "github.com/swaggo/gin-swagger"
{{- if .Centrifuge}}
	ws "{{.ModuleName}}/internal/controller/ws"
{{- end}}
)

{{- if .Centrifuge}}
func Controller(cfg Config, wsHandler *ws.Handler) *gin.Engine {
{{- else}}
func Controller(cfg Config) *gin.Engine {
{{- end}}
	r := gin.Default()

	r.Use(cors.New(cors.Config{
		AllowOrigins:     cfg.AllowOrigins,
		AllowMethods:     cfg.AllowMethods,
		AllowHeaders:     cfg.AllowHeaders,
		ExposeHeaders:    cfg.ExposeHeaders,
		AllowCredentials: cfg.AllowCredentials,
	}))

	r.GET("/ping", health.Handle)
	r.GET("/swagger/*any", ginSwagger.WrapHandler(swaggerFiles.Handler))

	api := r.Group("/api")
	_ = api.Group("/v1")
{{- if .Centrifuge}}

	// WebSocket эндпоинт. Centrifuge обрабатывает апгрейд соединения.
	r.GET("/ws", func(c *gin.Context) {
		wsHandler.ServeHTTP(c.Writer, c.Request)
	})
{{- end}}

	return r
}
